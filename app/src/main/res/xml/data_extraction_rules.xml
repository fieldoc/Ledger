<?xml version="1.0" encoding="utf-8"?>
<!-- API 31+ backup rules. Back up API key preferences so they survive reinstalls. -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="gemini_api_prefs.xml" />
        <include domain="sharedpref" path="weather_api_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="gemini_api_prefs.xml" />
        <include domain="sharedpref" path="weather_api_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
